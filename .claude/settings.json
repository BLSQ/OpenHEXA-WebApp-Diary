{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-destructive-git.js",
            "statusMessage": "Checking for destructive git/gh commands..."
          }
        ]
      }
    ]
  }
}
